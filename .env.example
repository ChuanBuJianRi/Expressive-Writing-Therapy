# ============= PRIMARY LLM (Story Generation) =============
# Used for: Director Agent, Character Agents, Story Composer
# Any OpenAI-compatible API: OpenAI, DeepSeek, Qwen, etc.
LLM_API_KEY=your_key
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL_NAME=gpt-4o

# ============= IBM watsonx.ai (REQUIRED for hackathon) =============
# Used for: Safety Filter, Sentiment Analysis
# Get from: https://cloud.ibm.com/watsonx-ai
WATSONX_API_KEY=your_ibm_api_key
WATSONX_PROJECT_ID=your_project_id
WATSONX_URL=https://us-south.ml.cloud.ibm.com

# ============= OPTIONAL: Secondary LLM (Boost/Fallback) =============
LLM_BOOST_API_KEY=
LLM_BOOST_BASE_URL=
LLM_BOOST_MODEL_NAME=

# ============= Server =============
FLASK_PORT=5001
FLASK_DEBUG=true
